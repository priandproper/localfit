{
  "name": "localfit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-data.mjs",
    "server": "node server/index.mjs",
    "vite": "vite --host",
    "predev": "npm run sync",
    "dev": "concurrently -k -n api,web -c green,cyan \"npm:server\" \"npm:vite\"",
    "build": "npm run sync && vite build",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7"
  }
}
